# Environment reference (optional — no env vars required currently)
# All APIs are public market data endpoints with no authentication.

# Binance Futures API endpoint
VITE_BINANCE_API=https://fapi.binance.com

# Bybit V5 API endpoint (fallback)
VITE_BYBIT_API=https://api.bybit.com

# If using a CORS proxy (only needed if browser CORS blocks localhost)
VITE_CORS_PROXY=https://cors-anywhere.herokuapp.com

# Refresh interval in seconds
VITE_REFRESH_INTERVAL=1200

# Default symbols (comma-separated)
VITE_SYMBOLS=BTC,ETH,SOL,BNB,XRP,DOGE,AVAX,LINK
